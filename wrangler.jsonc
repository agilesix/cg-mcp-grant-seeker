{
  // Cloudflare Workers config for the *remote* (hosted) MCP server — the
  // artifact submitted to the Claude Connectors Directory and OpenAI Apps SDK.
  // The local stdio server (src/stdio.ts) does not use this.
  //
  // The remote transport is the MCP SDK's Web-standard Streamable HTTP
  // transport, run statelessly in src/worker.ts. This needs no Durable Object.
  //
  // If applications functionality (mutations, per-consumer state, auth) is
  // added later, the upgrade path is Cloudflare's McpAgent — which WOULD need a
  // Durable Object. Re-add a `durable_objects` binding + `migrations` entry at
  // that point (see docs/adr/002-hosting-and-distribution.md).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cg-mcp-grant-seeker",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "vars": {
    // Non-secret config can go here. The federal API key is a SECRET — set it
    // with `wrangler secret put FEDERAL_API_TOKEN`, never here.
  },
}
