{
  // Cloudflare Workers config for the *remote* (hosted) MCP server — the
  // artifact submitted to the Claude Connectors Directory and OpenAI Apps SDK.
  // The local stdio server (src/stdio.ts) does not use this.
  //
  // This experimental branch uses Skybridge's generated Cloudflare entry and
  // serves the compiled grant-results view as static assets.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cg-mcp-grant-seeker",
  "main": "dist/__entry.js",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "dist/assets",
  },
  "define": {
    "process.env.NODE_ENV": "\"production\"",
  },
  "observability": {
    "enabled": true,
  },
  "vars": {
    "SKYBRIDGE_TELEMETRY_DISABLED": "1",
    // Non-secret config can go here. The federal API key is a SECRET — set it
    // with `wrangler secret put FEDERAL_API_TOKEN`, never here.
  },
}
